{
  "name": "forsyde-vscode-extension",
  "displayName": "ForSyDe DevTools",
  "description": "Visual Studio Extension for ForsyDe LSP Visualisation",
  "author": "ForSyDe DevTools",
  "license": "MIT",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sthaeron/forsyde-devtools"
  },
  "publisher": "forsyde-devtools",
  "categories": ["Programming Languages"],
  "keywords": [
    "multi-root ready"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onLanguage:haskell"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ForSyDe DevTools LSP",
      "type": "object",
      "properties": {
        "forsydeDevtoolsLSP.stackPkgPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Specify where the package DB which contains ForSyDe Shallow is located. Use the command: \n`find $HOME/.stack -name '*forsyde-shallow*' | grep -o '^.*/pkgdb'`. Invalid pathname will cause the LSP server to not start."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint",
    "package": "npx @vscode/vsce package",
    "postinstall": "cd client && npm install && cd .."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^9.13.0",
    "mocha": "^10.3.0",
    "prettier": "^3.7.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "extensionDependencies": [
    "kieler.klighd-vscode"
  ]
}
