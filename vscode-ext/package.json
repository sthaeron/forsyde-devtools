{
  "name": "forsyde-vscode-extension",
  "description": "Visual Studio Extension for Forsyde LSP Visualisation",
  "author": "Forsyde DevTools",
  "license": "MIT",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sthaeron/forsyde-devtools"
  },
  "publisher": "forsyde-devtools",
  "categories": [],
  "keywords": [
    "multi-root ready"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onLanguage:haskell"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == haskell",
          "command": "klighd-vscode.diagram.open",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint",
    "postinstall": "cd client && npm install && cd .."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22",
    "eslint": "^9.13.0",
    "mocha": "^10.3.0",
    "prettier": "^3.7.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "extensionDependencies": [
    "kieler.klighd-vscode"
  ]
}
