#!/bin/sh

# Pre-commit hook for ormolu
# Exit on any error
set -e

# Check if ormolu is installed
if ! command -v ormolu >/dev/null 2>&1; then
    echo "Error: ormolu not found. Please install it first."
    echo "Run: cabal install ormolu or stack install ormolu"
    exit 1
fi

# Get list of staged .hs and .lhs files
FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(hs|lhs)$' || true)

if [ -n "$FILES" ]; then
    echo "Formatting Haskell files with Ormolu..."
    echo "$FILES" | xargs ormolu --mode inplace
    
    # Add formatted files back to staging area
    echo "$FILES" | xargs git add
fi

echo "Pre-commit hook completed successfully"
exit 0
